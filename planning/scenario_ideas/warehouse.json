{
  "schema_version": "1.0",
  "task_id": "warehouse_pickup_v1",
  "title": "Warehouse Pickup Coordination",
  "domain": "logistics",
  "description": "Implement a MASPY multi-agent warehouse system where Worker agents pick up packages when assigned by a Manager agent. The Manager assigns tasks when new package percepts appear. Workers must complete assigned pickups and report completion.",

  "environment": {
    "type": "Warehouse",
    "name": "MainWarehouse",
    "channel": "WarehouseChannel",
    "initial_state": {
      "packages_waiting": 3
    },
    "percepts": [
      {
        "name": "package_available",
        "args": ["package_id"],
        "scope": "WarehouseChannel",
        "generation": {
          "trigger": "on_start",
          "count": 3
        }
      }
    ],
    "actions": [
      {
        "name": "pickup_package",
        "invoked_by": "Worker",
        "preconditions": ["assigned(package_id)"],
        "effects": ["package_picked(package_id)"]
      }
    ],
    "dynamics": {
      "step_limit": 100,
      "notes": "Packages are available at start; workers must coordinate to avoid duplicate pickup."
    }
  },

  "agents": [
    {
      "id": "manager",
      "type": "Manager",
      "role": "task_allocator",
      "count": 1,
      "initial_beliefs": [],
      "initial_goals": [],
      "triggers": [
        {
          "when": "gain_percept",
          "content": {
            "kind": "Percept",
            "name": "package_available",
            "args": ["package_id"],
            "scope": "WarehouseChannel"
          },
          "handler": "assign_package"
        }
      ],
      "behaviors": [
        {
          "name": "assign_package",
          "steps": [
            { "op": "select_worker", "params": {} },
            { "op": "send_goal", "params": { "goal": "pickup(package_id)" } }
          ],
          "stop_cycle_after": false
        }
      ]
    },
    {
      "id": "worker",
      "type": "Worker",
      "role": "package_handler",
      "count": 2,
      "initial_beliefs": [],
      "initial_goals": [],
      "triggers": [
        {
          "when": "gain_goal",
          "content": {
            "kind": "Goal",
            "name": "pickup",
            "args": ["package_id"],
            "scope": "WarehouseChannel"
          },
          "handler": "handle_pickup"
        }
      ],
      "behaviors": [
        {
          "name": "handle_pickup",
          "steps": [
            { "op": "perform_action", "params": { "action": "pickup_package" } },
            { "op": "send_message", "params": { "type": "completion", "content": "package_picked(package_id)" } }
          ],
          "stop_cycle_after": true
        }
      ]
    }
  ],

  "communication": {
    "channels": [
      { "name": "WarehouseChannel", "semantics": "Shared coordination channel between Manager and Workers" }
    ],
    "message_types": ["goal_assignment", "completion"]
  },

  "termination": {
    "mode": "event_driven",
    "step_limit": 100,
    "stop_conditions": ["all_packages_picked"]
  },

  "success_criteria": [
    {
      "name": "All packages picked exactly once",
      "definition": "Each initial package_available percept results in exactly one pickup_package action."
    }
  ],

  "metrics": {
    "primary": [
      {
        "name": "completion_rate",
        "definition": "Number of successfully picked packages divided by initial packages."
      }
    ],
    "secondary": [
      {
        "name": "duplicate_pickups",
        "definition": "Number of times multiple workers attempt to pick the same package."
      }
    ]
  },

  "seeds": {
    "scenario_seed": 42
  },

  "baseline": {
    "exists": true,
    "reference": "handwritten MASPY warehouse example",
    "notes": "Manual implementation used as ground truth comparison for LLM generation."
  }
}
